{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "remote": {
    "urls": [
      "https://newtopfront.netlify.app",
      "https://newtopfront.netlify.app/*"
    ]
  },
  "permissions": [
    "core:default",
    "powersync:default",
    "core:webview:default",
    "core:webview:allow-create-webview-window",
    "core:window:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "dialog:default",
    "printer:default",
    "printer:allow-print-html",
    "fs:default",
    "fs:allow-temp-write",
    "fs:allow-temp-write-recursive",
    "fs:allow-temp-read",
    "fs:allow-temp-read-recursive",
    "fs:allow-exists",
    "fs:allow-remove",
    "fs:allow-write-file",
    "fs:allow-read-file",
    "updater:default",
    "store:default",
    "process:default",
    "core:tray:default",
    "core:menu:default",
    "shell:allow-execute",
    "shell:allow-spawn"
  ]
}