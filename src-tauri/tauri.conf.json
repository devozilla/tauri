{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TOP DEV",
  "version": "1.0.0",
  "identifier": "com.top.erpdev",
  "build": {
    "devUrl": "http://localhost:5173/",
    "frontendDist": "https://www.top-dev.duckdns.org/"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "TOP DEV",
        "decorations": false,
